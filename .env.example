# Vite
# BASE_URL=/ (auto-set by Vite)
# VITE_BASE_URL=/ (auto-set by Vite)

# Server port (for auto-import and Next.js plugin)
# PORT=3000

# Chrome DevTools Protocol
# CHROME_CDP_URL=http://127.0.0.1:9222

# Sweetlink configuration
# SWEETLINK_DEV_URL=http://localhost:3000
# SWEETLINK_WS_PORT=9223
# SWEETLINK_WS_URL=ws://localhost:9223
# SWEETLINK_OPERATION_TIMEOUT=60000
# SWEETLINK_CLAUDE_MODEL=claude-sonnet-4-20250514
# SWEETLINK_VERBOSE=1                   # Enable verbose CLI logging.
# SWEETLINK_RUN=2026-04-27-1430         # Pin a run id for related captures (otherwise auto HHMM-SS).
# SWEETLINK_DEBUG=1                     # Print findProjectRoot debug traces.
# SWEETLINK_ALLOW_OUTSIDE_OUTPUT=1      # Allow --output paths outside the project root (default off; opt-in).

# Anthropic API (for design review feature)
# ANTHROPIC_API_KEY=sk-ant-...

# E2E test runner
# E2E_SCREENSHOT_MODE=update           # Set to "update" to refresh visual baselines.
